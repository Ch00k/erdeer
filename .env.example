# Server
PORT=3001
HOST=127.0.0.1
BASE_URL=http://localhost:7000

# Restrict signups to specific email domains (comma-separated, leave empty to allow all)
ALLOWED_DOMAINS=

# Database
DATABASE_PATH=data/db.sqlite

# OAuth providers (configure at least one)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
